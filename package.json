{
	"name": "holoid",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"lint": "biome check --write .",
		"test": "vitest",
		"test:coverage": "vitest run --coverage",
		"db:start": "npx supabase start",
		"db:stop": "npx supabase stop",
